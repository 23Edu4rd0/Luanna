# Environment Variables
# Copy this file to .env.local and fill in your values

# Server port (default: 3000)
PORT=3000

# ✏️ EDIT: Your PIX key for payments
# Can be: email, phone, CPF, or random key from your bank
PIX_KEY=your-pix-key@domain.com

# ✏️ EDIT: Couple names
COUPLE_NAMES=Luanna & Wendell

# ✏️ EDIT: Wedding date (YYYY-MM-DD)
WEDDING_DATE=2026-10-25
